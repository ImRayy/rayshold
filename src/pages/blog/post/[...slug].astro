---
import MetaInfo from "@components/blog/MetaInfo.astro";
import Layout from "@layouts/Layout.astro";
import { getWordsCount } from "@utils/helpers";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const words = getWordsCount(entry.body);
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
  <div class="w-full">
    <div class="pb-4">
      <h1 class="text-core-content select-none pb-4 text-2xl font-semibold">
        {entry.data.title}
      </h1>
      <div
        class="text-secondary-content flex select-none items-center gap-3 pb-4 font-medium"
      >
        <MetaInfo date={entry.data.publishDate} words={words} className="w-5" />
      </div>
    </div>
  </div>
  <!-- TITLE END -->
  <img src={entry.data.image?.src} alt={entry.data.image?.alt} />
  <!-- CONTENT START -->
  <div class="markdown">
    <Content />
  </div>
</Layout>
