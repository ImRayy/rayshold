---
import Social from "@components/ui/Social.astro";
import { sideBarConfig as config } from "@utils/sidebarConfig";
import Icon from "astro-icon";
import Divider from "./Divider.astro";
import Footer from "./Footer.astro";
import NavLink from "./NavLink.astro";
---

<div
  id="sidebar"
  class="noSelect bg-crust text-crust-content fixed left-0 top-0 z-50 h-full w-80 -translate-x-full overflow-y-auto border-r border-secondary transition-transform duration-500"
>
  <div
    class="relative flex h-full w-full flex-col justify-between overflow-y-auto px-2.5"
  >
    <div class="pt-1">
      <!-- HEADER START   -->
      <div class="flex w-full justify-center py-2 pt-4">
        <div class="flex flex-col items-center gap-5">
          <img
            src={config.sidebar.profile_image}
            alt={config.sidebar.profile_image}
            class="w-20 rounded-full"
          />
          <span class="text-xs font-bold tracking-widest">
            RAY <span class="px-1">I</span> LINUX ENTHUSIAST
          </span>
          <Social />
        </div>
      </div>
      <!-- HEADER END -->
      <!-- LINKS START -->
      <div class="flex flex-col gap-3 pt-4">
        <Divider>Navigation</Divider>
        {
          config.sidebar.links.navigation.map((n) => (
            <a href={n.link}>
              <NavLink>
                <Icon name={n.icon} class="w-6" />
                {n.label}
              </NavLink>
            </a>
          ))
        }
        <Divider>Interests</Divider>
        {
          config.sidebar.links.interests.map((i) => (
            <a href={i.link} target="_blank">
              <NavLink>
                <Icon name={i.icon} class="w-6" />
                {i.label}
              </NavLink>
            </a>
          ))
        }
        <Divider>checkout my</Divider>
        {
          config.sidebar.links.others.map((o) => (
            <a href={o.link} target="_blank">
              <NavLink>
                <Icon name={o.icon} class="w-6" />
                {o.label}
              </NavLink>
            </a>
          ))
        }
      </div>
      <!-- LINKS END -->
    </div>
    <!-- FOOTER START -->
    <div class="pb-4">
      <Footer />
    </div>
    <!-- FOOTER END -->
  </div>
</div>
